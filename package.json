    "fetch-core": "node scripts/fetch-cubism-core.mjs"
  },
  "dependencies": {
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10"
  },
  "devDependencies": {
    "electron": "^37.2.0"
  },
  "overrides": {
    "gh-pages": "^6.3.0"
  }
}
