{
  "name": "bikunavi-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Live2D desktop companion for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check renderer.js",
